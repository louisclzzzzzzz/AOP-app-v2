# Clé API Mistral (OCR + LLM). Obtenir sur https://console.mistral.ai/
MISTRAL_API_KEY=

# Clé API Perplexity (variante expérimentale Deep Research de la synthèse projet — Phase 1).
# Obtenir sur https://www.perplexity.ai/account/api/keys. Facultatif : sans cette clé, seul le
# bouton "Perplexity Deep Research" échoue proprement, le reste de l'application fonctionne.
PERPLEXITY_API_KEY=

# Répertoire de travail (dossiers en cours, cache OCR, DB SQLite).
# Laissez cette ligne commentée : la valeur par défaut est <racine_du_dépôt>/workspace
# (chemin absolu, calculé depuis l'emplacement du code — jamais depuis le répertoire courant).
# Si vous la renseignez, utilisez impérativement un chemin ABSOLU : ./start.sh lance le
# serveur depuis backend/, donc un chemin relatif comme "./workspace" pointerait vers
# backend/workspace/ (non ignoré par git) au lieu de la racine du dépôt.
# AOP_WORKSPACE_DIR=/chemin/absolu/vers/workspace

# Base SQLite (état des dossiers, cache OCR, résultats).
# Laissez cette ligne commentée : dérivée automatiquement de AOP_WORKSPACE_DIR.
# AOP_DATABASE_URL=sqlite:////chemin/absolu/vers/workspace/aop.db

# Port du backend FastAPI
AOP_BACKEND_PORT=8000

# Port du frontend Vite (dev)
AOP_FRONTEND_PORT=5173
