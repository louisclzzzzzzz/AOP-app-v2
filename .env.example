# Clé API Mistral (OCR + LLM). Obtenir sur https://console.mistral.ai/
MISTRAL_API_KEY=

# Répertoire de travail (dossiers en cours, cache OCR, DB SQLite)
AOP_WORKSPACE_DIR=./workspace

# Base SQLite (état des dossiers, cache OCR, résultats)
AOP_DATABASE_URL=sqlite:///./workspace/aop.db

# Port du backend FastAPI
AOP_BACKEND_PORT=8000

# Port du frontend Vite (dev)
AOP_FRONTEND_PORT=5173
